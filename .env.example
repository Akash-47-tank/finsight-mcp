# FinSight MCP — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Ollama (local LLM — FREE) ─────────────────────────────────────────────
# Default: http://localhost:11434 (standard Ollama port)
OLLAMA_BASE_URL=http://localhost:11434

# Model to use — must be pulled first: ollama pull llama3.2
# Recommended models for M1 Mac (fast + accurate):
#   llama3.2      (3B — very fast on M1)
#   llama3.1:8b   (8B — better quality, still fast on M1)
#   mistral       (7B — great for financial analysis)
#   gemma3        (balanced)
OLLAMA_MODEL=llama3.2

# ── NewsAPI (optional, free tier: 100 req/day) ────────────────────────────
# Get your free key at: https://newsapi.org/register
# If not set, the client falls back to yfinance news (still works!)
NEWS_API_KEY=your_newsapi_key_here
